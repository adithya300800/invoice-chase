generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  createdAt     DateTime      @default(now())
  connections   Connection[]
  invoices      Invoice[]
  settings      UserSettings?
  subscription  Subscription?
}

model Connection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  provider     String    // "gmail" | "quickbooks"
  accessToken String
  refreshToken String?
  expiresAt    DateTime?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  invoices    Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  connectionId  String?
  connection    Connection?   @relation(fields: [connectionId], references: [id])
  clientName    String
  invoiceNumber String
  amount        Float
  currency      String        @default("USD")
  issueDate     DateTime
  dueDate       DateTime
  status        String        @default("pending") // "pending" | "overdue" | "paid"
  quickbooksId  String?
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  drafts        FollowUpDraft[]
  createdAt     DateTime      @default(now())
}

model Client {
  id        String    @id @default(cuid())
  userId    String
  name      String
  email     String?
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model FollowUpDraft {
  id         String    @id @default(cuid())
  invoiceId  String
  invoice    Invoice   @relation(fields: [invoiceId], references: [id])
  emailBody  String
  subject    String
  tone       String    @default("friendly") // "friendly" | "firm" | "formal"
  status     String    @default("draft") // "draft" | "sent" | "ignored"
  sentAt     DateTime?
  sentLog    SentLog?
  createdAt  DateTime  @default(now())
}

model SentLog {
  id              String       @id @default(cuid())
  followUpDraftId String       @unique
  followUpDraft   FollowUpDraft @relation(fields: [followUpDraftId], references: [id])
  recipientEmail  String
  sentAt          DateTime     @default(now())
}

model Subscription {
  id                  String   @id @default(cuid())
  userId              String   @unique
  stripeCustomerId    String   @unique
  stripeSubscriptionId String   @unique
  plan                String   @default("trial") // "trial" | "monthly" | "annual"
  status              String   @default("trialing") // "trialing" | "active" | "past_due" | "canceled"
  trialEndsAt         DateTime?
  currentPeriodEnd    DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  defaultTone   String  @default("friendly")
  timezone      String  @default("America/New_York")
  emailFromName String  @default("Invoice Chase")
  reminderDays  Int     @default(7)
}
